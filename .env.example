# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# OpenAI API key — used by /api/analyze (server-side only, never exposed to the browser)
OPENAI_API_KEY=

# Fixture vs live. Unset → fixture (frozen mock, zero OpenAI). "false" → live
# pipeline. Set NEXT_PUBLIC_USE_FIXTURE=false in Vercel (production) and here
# for local live testing.
NEXT_PUBLIC_USE_FIXTURE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx...
SUPABASE_SECRET_KEY=sb_secret_xxx...

# --- Step 4c: news adapters (server-side only) -------------------------------
# Google News RSS needs no key. The others do:
#
# Naver 뉴스 검색 (KR): developers.naver.com → 애플리케이션 등록 →
#   사용 API "검색" 추가 → Client ID / Client Secret 발급 (무료)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
#
# Finnhub (US company-news): finnhub.io 무료 가입 → Dashboard 의 API key
FINNHUB_API_KEY=
#
# Yahoo Finance via RapidAPI (optional, lowest priority — unstable):
#   rapidapi.com 의 Yahoo Finance API 구독 → X-RapidAPI-Key
RAPIDAPI_KEY=
#
# Step 4c pipeline switch (server-side, /api/analyze):
#   true  → news adapters fetch real articles → GPT classifies (real source/date)
#   unset → legacy web_search path (default)
# USE_NEWS_ADAPTERS=true
#
# Step 4c-6 read-through cache TTL in ms (stock_analysis table). Default 3h.
#   Set 0 to recompute every request while testing. Requires migration 002.
# STOCK_CACHE_TTL_MS=10800000

# Step 4c-7 scheduled refresh (Vercel Cron → GET /api/refresh).
#   CRON_SECRET: shared secret. Vercel auto-injects "Authorization: Bearer <it>"
#   into cron requests; the route rejects anything else. Set it in Vercel too.
CRON_SECRET=
#   REFRESH_MODE: "test" (refresh every 2 days) or "live" (market-aware 5/30
#   min, see src/lib/refresh-schedule.ts). Default test. Cadence knobs live in
#   that file — edit + push to change frequency.
# REFRESH_MODE=live
#
# Step 5 prediction engine (server-side; predictStock in /api/refresh +
# /api/predict-stock). Switchable any time — no code change:
#   "gpt"   → one gpt-4o-mini call outputs color/impact-period/band/서술 (default)
#   "model" → case-based k-NN aggregation over the event store
# PREDICTION_MODE=gpt

# Step 4e #3: company logos in the search dropdown (logo.dev, by ticker).
#   Get a free publishable token at https://logo.dev (it's a client img src, so
#   it's public). US tickers show logos; KR / missing → white-circle placeholder.
NEXT_PUBLIC_LOGODEV_TOKEN=